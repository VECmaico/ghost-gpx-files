<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  const map = L.map('map').setView([48.0, 2.0], 6);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap contributors'
  }).addTo(map);

  // Custom Icon for Camping
  const campingIcon = L.icon({
    iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-red.png',
    shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
    iconSize: [25, 41], iconAnchor: [12, 41], popupAnchor: [1, -34]
  });

  const allWaypoints = L.featureGroup().addTo(map);
  const campingWaypoints = L.featureGroup();

  const manifests = [
    'https://raw.githubusercontent.com/VECmaico/ghost-gpx-files/refs/heads/main/GPX/2025manifest.json',
    'https://raw.githubusercontent.com/VECmaico/ghost-gpx-files/refs/heads/main/GPX/2026manifest.json',
    'https://raw.githubusercontent.com/VECmaico/ghost-gpx-files/refs/heads/main/GPX/2027manifest.json'
  ];

  async function loadData() {
    for (const url of manifests) {
      try {
        const response = await fetch(url);
        const data = await response.json();
        
        data.forEach(item => {
          // Standard marker for all
          const marker = L.marker([item.lat, item.lon]).bindPopup(item.name);
          allWaypoints.addLayer(marker);
          
          // Check for 'wildcamping' in name
          if (item.name && item.name.toLowerCase().includes('wildcamping')) {
            const cMarker = L.marker([item.lat, item.lon], {icon: campingIcon}).bindPopup(item.name);
            campingWaypoints.addLayer(cMarker);
          }
        });
      } catch (err) { console.error("Error loading JSON:", err); }
    }
    
    // Zoom to fit all visible markers
    map.fitBounds(allWaypoints.getBounds(), { padding: [20, 20] });
  }

  // Toggle control
  const overlays = { "All Waypoints": allWaypoints, "Wild Camping": campingWaypoints };
  L.control.layers(null, overlays, {collapsed: false}).addTo(map);
  
  loadData();
</script>
